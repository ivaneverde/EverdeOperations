# Copy to .env.local and fill in (never commit .env.local)

# Entra ID SPA — Application (client) ID from App registrations
NEXT_PUBLIC_MS_ENTRA_CLIENT_ID=

# Tenant: Everde directory (tenant) GUID, or "organizations" if you prefer multi-tenant sign-in
NEXT_PUBLIC_MS_ENTRA_TENANT_ID=

# Entra SPA redirect URIs must include this path (popup / silent bridge):
#   http://localhost:3000/auth/msal-bridge
# plus your production origin with the same path when deployed.

# Share root for server-side file reads (Freight HTML, CSV exports, etc.). Forward slashes for UNC, e.g. //192.168.190.10/Claude Sandbox/DataDrops
PORTAL_DATA_ROOT=

# Optional: exact path to one Everde Freight dashboard HTML; if unset, newest Everde_Freight_Dashboard*.html under Freight/ is used.
# FREIGHT_DASHBOARD_HTML=

# 1 = allow POST /api/freight/run-pipeline (runs Freight/_pipeline/update.py). Use only on trusted dev/ops hosts.
FREIGHT_ALLOW_PIPELINE=

# Python for freight pipeline. On Windows, if `python` is only the Microsoft Store stub,
# set the full path, e.g. FREIGHT_PYTHON=C:\Python312\python.exe or FREIGHT_PYTHON=py -3
# FREIGHT_PYTHON=

# Optional: freight pipeline timeout in ms (default 900000).
# FREIGHT_PIPELINE_TIMEOUT_MS=

# Server-only: folder containing Sales Manager Summary CSV exports (see src/config/salesManagerSummarySheets.ts)
PORTAL_CSV_ROOT=
