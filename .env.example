# Copy to .env.local and fill in (never commit .env.local)

# Entra ID SPA — Application (client) ID from App registrations
NEXT_PUBLIC_MS_ENTRA_CLIENT_ID=

# Tenant: Everde directory (tenant) GUID, or "organizations" if you prefer multi-tenant sign-in
NEXT_PUBLIC_MS_ENTRA_TENANT_ID=

# Entra SPA redirect URIs must include this path (popup / silent bridge):
#   http://localhost:3000/auth/msal-bridge
# plus your production origin with the same path when deployed.

# Share root for server-side file reads (Freight HTML, CSV exports, etc.). Forward slashes for UNC, e.g. //192.168.190.10/Claude Sandbox/DataDrops
PORTAL_DATA_ROOT=

# Optional: full path to dashboard workbook (Everde_Freight_Dashboard*.xlsb with _history tabs). Overrides auto-pick under PORTAL_DATA_ROOT/Freight.
# Used by: npm run freight:extract-publish
# FREIGHT_DASHBOARD_XLSB=

# Optional: exact path to one Everde Freight dashboard HTML (e.g. a Downloads export). If unset, the app picks the newest
# Everde_Freight_Dashboard*.html by mtime in public/ OR under PORTAL_DATA_ROOT/Freight (see FREIGHT_DASHBOARD_DATA.md).
# FREIGHT_DASHBOARD_HTML=

# 1 = allow POST /api/freight/run-pipeline (runs Freight/_pipeline/update.py). Use only on trusted dev/ops hosts.
FREIGHT_ALLOW_PIPELINE=

# Python for freight pipeline. On Windows, if `python` is only the Microsoft Store stub,
# set the full path, e.g. FREIGHT_PYTHON=C:\Python312\python.exe or FREIGHT_PYTHON=py -3
# FREIGHT_PYTHON=

# Optional: freight pipeline timeout in ms (default in code: 1 hour for full update.py).
# FREIGHT_PIPELINE_TIMEOUT_MS=

# Server-only: folder containing Sales Manager Summary CSV exports (see src/config/salesManagerSummarySheets.ts)
PORTAL_CSV_ROOT=

# --- Azure Blob (hosted freight JSON + incoming uploads) ---
# Connection string from Storage Account → Access keys (server-only; never NEXT_PUBLIC).
# AZURE_STORAGE_CONNECTION_STRING=

# Container name (create in Azure portal). Must match between publish script and app.
# AZURE_FREIGHT_BLOB_CONTAINER=everde-freight

# Path to live dashboard JSON inside the container (Block Blob).
# AZURE_FREIGHT_DASHBOARD_JSON_BLOB=freight/latest/dashboard_data.json

# Prefix for POST /api/admin/freight-upload (default incoming).
# AZURE_FREIGHT_INCOMING_PREFIX=incoming

# Optional: full path to a local dashboard_data.json for GET /api/freight/dashboard-data when Blob is empty.
# PUBLIC_FREIGHT_DASHBOARD_JSON=

# Optional: shared secret for automation (header x-everde-admin-key). If unset, upload requires Entra Bearer.
# EVERDE_ADMIN_UPLOAD_KEY=

# Tenant GUID for JWT verification on uploads (same as NEXT_PUBLIC_MS_ENTRA_TENANT_ID for single-tenant).
# AZURE_AD_TENANT_ID=

# Allowed email domain for uploads when using Bearer token (no leading @).
# EVERDE_ALLOWED_EMAIL_DOMAIN=everde.com

# Optional max upload bytes (default 80MB).
# EVERDE_FREIGHT_UPLOAD_MAX_BYTES=

# --- Planned multi-section DataDrops layout (optional; PORTAL_DATA_ROOT remains canonical today) ---
# DATADROPS_ROOT=//192.168.190.10/Claude Sandbox/DataDrops
# KEY_ITEM_ALLOW_PIPELINE=
# SALES_PLAN_ALLOW_PIPELINE=
