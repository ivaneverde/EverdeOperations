# Microsoft Bot Framework (Azure Bot / Entra app registration)
MicrosoftAppId=
MicrosoftAppPassword=
# Recommended for Everde internal use:
MicrosoftAppType=SingleTenant
MicrosoftAppTenantId=

# Server
PORT=3978

# Anthropic Claude
ANTHROPIC_API_KEY=
# Match a model your Anthropic account supports (portal uses claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# Conversation memory (messages per user thread in Teams)
CONVERSATION_MAX_TURNS=20

# File attachments (Teams → Claude)
ATTACHMENT_MAX_BYTES=20971520
ATTACHMENT_MAX_EXCEL_ROWS=500

# Optional system instructions for the assistant persona
# CLAUDE_SYSTEM_PROMPT=You are a helpful executive assistant for Everde leadership...
