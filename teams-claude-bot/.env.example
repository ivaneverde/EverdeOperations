# Microsoft Bot Framework (Azure Bot / Entra app registration)
MicrosoftAppId=
MicrosoftAppPassword=
# Recommended for Everde internal use:
MicrosoftAppType=SingleTenant
MicrosoftAppTenantId=

# Server
PORT=3978

# Anthropic Claude
ANTHROPIC_API_KEY=
# Match a model your Anthropic account supports (portal uses claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# Conversation memory (messages per user thread in Teams)
CONVERSATION_MAX_TURNS=20

# File attachments (Teams → Claude)
ATTACHMENT_MAX_BYTES=20971520
# Full spreadsheet rows for Teams file analysis (landscape inventory ~6.4k rows)
ATTACHMENT_MAX_EXCEL_ROWS=10000
# Cached file text for follow-up questions in the same chat
CONVERSATION_FILE_MAX_CHARS_PER_FILE=2000000
CONVERSATION_FILE_MAX_TOTAL_CHARS=4000000
# Retail tool response size (all stores, no top-20 cap)
EVERDE_RETAIL_TOOL_MAX_CHARS=120000

# Optional system instructions for the assistant persona
# CLAUDE_SYSTEM_PROMPT=You are a helpful executive assistant for Everde leadership...

# Everde portal data (Azure Blob — same connection as AI Operations portal)
AZURE_STORAGE_CONNECTION_STRING=
# AZURE_FREIGHT_BLOB_CONTAINER=everde-freight
# AZURE_FREIGHT_DASHBOARD_JSON_BLOB=freight/latest/dashboard_data.json
# AZURE_SALES_PLAN_DASHBOARD_JSON_BLOB=sales-plan/latest/sales_plan_data.json
# AZURE_RETAIL_DASHBOARD_JSON_BLOB=retail-opportunity/latest/retail_opp_data.json
# AZURE_WEATHER_DASHBOARD_JSON_BLOB=weather-data/latest/weather_dashboard_data.json
# AZURE_NURSERY_DEMAND_JSON_BLOB=

# Web search: on-demand only (weather, news, "search the web"). Set 0 to disable.
ENABLE_WEB_SEARCH=1
# WEB_SEARCH_MAX_USES=3
# EVERDE_SNAPSHOT_CACHE_MS=300000
